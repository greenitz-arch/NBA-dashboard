# ── balldontlie API ──────────────────────────────────────────────────────────
# Get your free key at https://www.balldontlie.io
# Then add it to Netlify: Site Settings → Environment Variables
BALLDONTLIE_API_KEY=your_api_key_here

# ── Cache revalidation ───────────────────────────────────────────────────────
# A random secret string — used to protect the /api/revalidate endpoint
# Generate one at: https://generate-secret.vercel.app/32
REVALIDATE_SECRET=your_random_secret_here
